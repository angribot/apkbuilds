pkgname=zerostack
pkgver=1.7.1
pkgrel=0
pkgdesc="Minimalistic coding agent written in Rust"
url="https://github.com/gi-dellav/zerostack"
arch="x86_64 aarch64"
license="GPL-3.0-only"
depends="bash"
options="!check !strip" # staged APK is tested with its repository read-only

case "$CARCH" in
x86_64)
	_sha512="d8f632a322fcae0e4c2449059021acac0eb8c0751f83a39752419f0e0a9005c56565a9c89f975a5607093b2cdf7fd2ae2325797dd229d1c2e6094822552b9a50"
	;;
aarch64)
	_sha512="b9269ae9d64ea878f2a989fb9a7f420ac62e761bb0c0fd94ceb053b359265211d61359cc4ec456fceafc36048bae7160d983bfdd6fd36c9adbb17bfeb02e8b7b"
	;;
esac
source="zerostack-$pkgver-$CARCH.tar.gz::https://github.com/gi-dellav/zerostack/releases/download/v$pkgver/zerostack-$CARCH-unknown-linux-musl.tar.gz"

package() {
	install -Dm755 "$srcdir/zerostack-$CARCH-unknown-linux-musl" \
		"$pkgdir/usr/bin/zerostack"
}

sha512sums="
$_sha512  zerostack-$pkgver-$CARCH.tar.gz
"
